{
  "ai": {
    "provider": "custom",
    "apiKey": "YOUR_API_KEY_HERE",
    "model": "YOUR_MODEL_ID",
    "baseUrl": "https://your-api-endpoint/v1",
    "compatibility": "openai"
  },
  "gateway": {
    "port": 18789,
    "bind": "loopback"
  },
  "workspace": {
    "dir": ""
  },
  "skills": {
    "enabled": [],
    "nodeManager": "npm"
  },
  "hooks": {
    "enabled": [],
    "enableInternal": true
  }
}
